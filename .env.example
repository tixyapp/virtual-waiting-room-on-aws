# ── Environment template — Virtual Waiting Room ───────────────────────────────
# Copy to .env.dev or .env.prod and fill in the blanks.
#   cp .env.example .env.dev
#   source .env.dev

# ── AWS credentials & targeting ───────────────────────────────────────────────
ENV=                              # dev | prod
PROFILE=                          # aws cli profile name (e.g. tixy-dev)
REGION=eu-west-1

# ── CloudFormation stacks ─────────────────────────────────────────────────────
STACK_NAME=                       # e.g. ye-poland-waiting-room-dev
INLET_STACK_NAME=                 # e.g. ye-poland-inlet-dev

# ── Build / deploy ────────────────────────────────────────────────────────────
BUILD_BUCKET=                     # artifact bucket base name (bucket = $BUILD_BUCKET-$REGION)
SOLUTION_NAME=virtual-waiting-room-on-aws
VERSION=v1.1.12

# ── Per-sale (update before each new event) ───────────────────────────────────
EVENT_ID=                         # unique slug per sale, e.g. ye-poland-2026-04
INCREMENT_BY=                     # users admitted per minute = tickets / sale_duration_min

# ── CloudFormation outputs (fill in after first deploy) ───────────────────────
PUBLIC_API_URL=                   # Outputs: PublicApiInvokeURL  (CloudFront URL)
PRIVATE_API_URL=                  # Outputs: PrivateApiInvokeURL (API Gateway URL)

# ── Static site ───────────────────────────────────────────────────────────────
STATIC_SITE_BUCKET=               # S3 bucket hosting queue + buy-ticket pages
STATIC_SITE_CF_ID=                # CloudFront distribution ID for static site
STATIC_SITE_URL=                  # CloudFront domain for static site

# ── Exports ───────────────────────────────────────────────────────────────────
export ENV PROFILE REGION STACK_NAME INLET_STACK_NAME
export BUILD_BUCKET SOLUTION_NAME VERSION
export EVENT_ID INCREMENT_BY
export PUBLIC_API_URL PRIVATE_API_URL
export STATIC_SITE_BUCKET STATIC_SITE_CF_ID STATIC_SITE_URL

CFN="aws cloudformation --profile $PROFILE --region $REGION"
LAM="aws lambda        --profile $PROFILE --region $REGION"
EVT="aws events        --profile $PROFILE --region $REGION"
S3C="aws s3            --profile $PROFILE"
export CFN LAM EVT S3C

echo "✓ $ENV env loaded — profile=$PROFILE  event=$EVENT_ID  stack=$STACK_NAME"
